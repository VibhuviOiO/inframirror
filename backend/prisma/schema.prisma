generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  datacenters Datacenter[]
}

model Environment {
  id   Int    @id @default(autoincrement())
  name String @unique  // e.g., "dev", "stage", "prod"
  apps Application[]
}

model Team {
  id        Int                  @id @default(autoincrement())
  name      String               @unique
  apps      Application[]        
  appCatalogs ApplicationCatalog[] 
}

model ServiceOrAppType {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  services  ServiceCatalog[]
  apps      ApplicationCatalog[]
}

model ServiceCatalog {
  id             Int          @id @default(autoincrement())
  name           String
  defaultPort    Int?
  description    String?
  serviceTypeId  Int
  serviceType    ServiceOrAppType @relation(fields: [serviceTypeId], references: [id])
  deployments    Service[]
}

model ApplicationCatalog {
  id             Int          @id @default(autoincrement())
  name           String
  uniqueId       String @unique
  defaultPort    Int?
  description    String?
  appTypeId      Int
  gitRepoUrl     String?
  teamId         Int
  team          Team @relation(fields: [teamId], references: [id])
  appType        ServiceOrAppType @relation(fields: [appTypeId], references: [id])
  apps           Application[]
}

model Datacenter {
  id           Int        @id @default(autoincrement())
  name         String
  shortName    String
  privateCIDR  String?
  publicCIDR   String?
  regionId     Int
  region       Region     @relation(fields: [regionId], references: [id])
  hosts        Host[]
  services     Service[]
  applications Application[]
}

enum HostKind {
  VM
  Physical
  BareMetal
}

model Host {
  id           Int        @id @default(autoincrement())
  datacenterId Int
  hostname     String     @unique
  privateIP    String
  publicIP     String?
  kind         HostKind
  tags         Json?

  datacenter   Datacenter @relation(fields: [datacenterId], references: [id])
  services     Service[]
  applications Application[]
}

model Service {
  id              Int            @id @default(autoincrement())
  datacenterId    Int
  hostId          Int
  catalogId       Int

  datacenter      Datacenter     @relation(fields: [datacenterId], references: [id])
  host            Host           @relation(fields: [hostId], references: [id])
  catalog         ServiceCatalog @relation(fields: [catalogId], references: [id])
}

model Application {
  id           Int                @id @default(autoincrement())
  datacenterId Int
  hostId       Int?
  catalogId    Int
  teamId       Int?
  environmentId Int?

  datacenter   Datacenter         @relation(fields: [datacenterId], references: [id])
  host         Host?              @relation(fields: [hostId], references: [id])
  catalog      ApplicationCatalog @relation(fields: [catalogId], references: [id])
  team         Team?              @relation(fields: [teamId], references: [id])
  environment  Environment?       @relation(fields: [environmentId], references: [id])
}