generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  datacenters Datacenter[]
}

model Environment {
  id   Int    @id @default(autoincrement())
  name String @unique  // e.g., "dev", "stage", "prod"
  apps Application[]
}

model Team {
  id        Int                  @id @default(autoincrement())
  name      String               @unique
  apps      Application[]
  catalogs  Catalog[]
}

model CatalogType {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  catalogs    Catalog[]
}

model Catalog {
  id          Int       @id @default(autoincrement())
  name        String
  uniqueId    String?   @unique
  defaultPort Int?
  description String?
  gitRepoUrl  String?
  teamId      Int? 
  team        Team?     @relation(fields: [teamId], references: [id])

  catalogTypeId Int
  catalogType   CatalogType @relation(fields: [catalogTypeId], references: [id])
  services     Service[]
  applications Application[]
}


model Datacenter {
  id           Int        @id @default(autoincrement())
  name         String
  shortName    String
  privateCIDR  String?
  publicCIDR   String?
  regionId     Int
  region       Region     @relation(fields: [regionId], references: [id])
  hosts        Host[]
  services     Service[]
  applications Application[]
}

enum HostKind {
  VM
  Physical
  BareMetal
}

model Host {
  id           Int        @id @default(autoincrement())
  datacenterId Int
  hostname     String     @unique
  privateIP    String
  publicIP     String?
  kind         HostKind
  tags         Json?

  datacenter   Datacenter @relation(fields: [datacenterId], references: [id])
  services     Service[]
  applications Application[]
}

model Service {
  id              Int            @id @default(autoincrement())
  datacenterId    Int
  hostId          Int
  catalogId       Int

  datacenter      Datacenter     @relation(fields: [datacenterId], references: [id])
  host            Host           @relation(fields: [hostId], references: [id])
  catalog         Catalog @relation(fields: [catalogId], references: [id])
}

model Application {
  id           Int                @id @default(autoincrement())
  datacenterId Int
  hostId       Int?
  catalogId    Int
  teamId       Int?
  environmentId Int?

  datacenter   Datacenter         @relation(fields: [datacenterId], references: [id])
  host         Host?              @relation(fields: [hostId], references: [id])
  catalog      Catalog @relation(fields: [catalogId], references: [id])
  team         Team?              @relation(fields: [teamId], references: [id])
  environment  Environment?       @relation(fields: [environmentId], references: [id])
}