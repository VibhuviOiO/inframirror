generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  datacenters Datacenter[]
}

model Environment {
  id        Int        @id @default(autoincrement())
  name      String     @unique  // e.g., "dev", "stage", "prod"
  services  Service[]
  clusters  Cluster[]
}

model Team {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  services  Service[]
  catalogs  Catalog[]
}

model CatalogType {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  catalogs    Catalog[]
}

model Catalog {
  id          Int       @id @default(autoincrement())
  name        String
  uniqueId    String?   @unique
  defaultPort Int?
  description String?
  gitRepoUrl  String?
  teamId      Int? 
  team        Team?     @relation(fields: [teamId], references: [id])

  catalogTypeId Int
  catalogType   CatalogType @relation(fields: [catalogTypeId], references: [id])

  services      Service[]
  clusters      Cluster[]
}

model Datacenter {
  id           Int        @id @default(autoincrement())
  name         String
  shortName    String
  privateCIDR  String?
  publicCIDR   String?
  regionId     Int
  region       Region     @relation(fields: [regionId], references: [id])
  hosts        Host[]
  services     Service[]
  clusters     Cluster[]
}

enum HostKind {
  VM
  Physical
  BareMetal
}

model Host {
  id           Int        @id @default(autoincrement())
  datacenterId Int
  hostname     String     @unique
  privateIP    String
  publicIP     String?
  kind         HostKind
  tags         Json?

  datacenter   Datacenter @relation(fields: [datacenterId], references: [id])
  services     Service[]
}

model Cluster {
  id            Int        @id @default(autoincrement())
  name          String
  catalogId     Int
  environmentId Int?
  datacenterId  Int?

  catalog       Catalog     @relation(fields: [catalogId], references: [id])
  environment   Environment? @relation(fields: [environmentId], references: [id])
  datacenter    Datacenter? @relation(fields: [datacenterId], references: [id])

  services      Service[]
}

model Service {
  id              Int         @id @default(autoincrement())
  datacenterId    Int?
  hostId          Int
  catalogId       Int?
  environmentId   Int?
  metadata        Json        @db.JsonB
  clusterId       Int?
  teamId          Int?

  datacenter      Datacenter? @relation(fields: [datacenterId], references: [id])
  host            Host        @relation(fields: [hostId], references: [id])
  catalog         Catalog?    @relation(fields: [catalogId], references: [id])
  environment     Environment? @relation(fields: [environmentId], references: [id])
  cluster         Cluster?    @relation(fields: [clusterId], references: [id])
  team            Team?       @relation(fields: [teamId], references: [id])
}
